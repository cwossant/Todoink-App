{
  // Keep VS Code responsive by excluding generated outputs and the embedded
  // Flutter SDK checkout from file watching and search.
  "files.watcherExclude": {
    "**/build/**": true,
    "**/.dart_tool/**": true,
    "**/.gradle/**": true,
    "flutter/**": true
  },
  "search.exclude": {
    "**/build/**": true,
    "**/.dart_tool/**": true,
    "**/.gradle/**": true,
    "flutter/**": true
  },
  "files.exclude": {
    "flutter/**": true
  }
}
